{"date_key":"2026-11-19","tibetan_year_name_en":"Fire Horse","image_key":"auspicious_days_octguru","gregorian":{"year":2026,"year_bo":"༢༠༢༦","month_en":"NOV","month_bo":"ཕྱི་ཟླ་བཅུ་གཅིག་པ།","date":19,"date_bo":"༡༩","weekday_en":"Thursday","weekday_bo":"ཕུར་བུ།"},"tibetan":{"year_en":"2153","year_bo":"༢༡༥༣","year_name_en":"Fire Horse","year_name_bo":"མེ་ཕོ་རྟ་ལོ།","month_en":"10","month_bo":"༡༠༽","month_name_en":"Mindruk-Dawa","month_name_bo":"སྨིན་དྲུག་ཟླ་བ།","animal_month_en":"Ox","animal_month_bo":"གླང་ཟླ།","day_en":"10","day_bo":"༡༠༽","lunar_status_en":null,"lunar_status_bo":null},"significance":{"day_significance_en":"Guru Dorjé Drolö\nOn the tenth day of the ox month, master and disciples confer,\nAnd in the centre and on the borders of the land of snows you conceal millions of terma troves.\nWith these treasures you safeguard what remains of the teachings, all with your constant kindness\nAll-powerful Dorje Drolö, to you we pray.\nGrant your blessing so that sudden misfortune, like untimely death, never befalls us,\nAnd as soon as we transfer to the next life, we are born in the pure realm of Great Bliss,\nAnd in the paradise of Lotus Light, in your very presence, Guru,\nAnd become a source of limitless benefit to living beings.","day_significance_bo":"གླང་ཟླའི་ཚེས་བཅུར་མཆོད་ཡོན་བཀའ་བགྲོས་ཏེ། །\nགངས་ཅན་མཐའ་དབུས་གཏེར་ཁ་བྱེ་སྙེད་སྦས། །\nབསྟན་ཞབས་གཏེར་སྐྱོང་བཀའ་དྲིན་རྒྱུན་ཆད་མེད། །\nརྡོ་རྗེ་གྲོ་ལོད་རྩལ་ལ་གསོལ་བ་འདེབས། །\nདུས་མིན་འཆི་སོགས་འཕྲལ་རྐྱེན་མི་འབྱུང་ཞིང༌། །\nའཕོས་མ་ཐག་ཏུ་བདེ་ཆེན་ཞིང་ཁམས་དང༌། །\nཔདྨ་འོད་དུ་གུ་རུའི་དྲུང་སྐྱེས་ནས། །\nའགྲོ་དོན་དཔག་མེད་འབྱུང་བར་བྱིན་གྱིས་རློབས། །","element_combo_en":"Wind-Earth","element_combo_bo":"རླུང་ས།","meaning_of_coincidence_en":"Unsuitable: Exhausts prosperity; brings thieves and robbers.","meaning_of_coincidence_bo":"མི་འཕྲོད་པ།"},"auspicious_day":{"name_en":"Guru Rinpoche Day","name_bo":"གུ་རུ་རིན་པོ་ཆེའི་ཉིན་མོ།","short_description_en":"A sacred day to honor Guru Padmasambhava, strengthen guru devotion, and renew Vajrayana commitments.","short_description_bo":"སློབ་དཔོན་པདྨ་འབྱུང་གནས་ལ་མཆོད་བསྟོད་བྱེད་པ་དང་། བླ་མའི་རྣལ་འབྱོར་བརྟན་པོ་བཟོ་བ། གསང་སྔགས་རྡོ་རྗེ་ཐེག་པའི་དམ་ཚིག་གསོ་བར་བྱེད་པའི་དུས་ཆེན་ཁྱད་པར་ཅན་ཞིག་ཡིན།"},"astrology_cards":[{"type":"naga_day","status_en":"avoid","status_bo":"ངན།","image_key":"astrology_naga_days_sleep","popup_ref":"naga-sleep_popup_ref"},{"type":"flag_day","status_en":"auspicious","status_bo":"བཟང་།","image_key":"astrology_flag_days","popup_ref":"flag_popup_ref"},{"type":"fire_ritual","status_en":"extremely_auspicious","status_bo":"ཤིན་ཏུ་བཟང་།","image_key":"astrology_fire_rituals","popup_ref":"fire_popup_ref"},{"type":"hair_cutting","status_en":"extremely_auspicious","status_bo":"ཤིན་ཏུ་བཟང་།","image_key":"astrology_hair_cutting","popup_ref":"hair_cutting_popup_ref"}],"torma_offering":{"direction_en":"southeast","image_key":"astrology_torma_offerings","popup_ref":"torma_popup_ref"},"empty_vase":{"direction_en":"north","image_key":"astrology_empty_vase","popup_ref":"empty_vase_popup_ref"},"daily_restriction":{"description_en":"avoid Important Activities","image_key":"astrology_daily_restrictions_general","popup_ref":"daily_restrictions_popup_ref"},"auspicious_times":{"description_en":"5:00 AM · 12:00 PM · 5:00 PM · 12:00 AM","image_key":"astrology_auspicious_time","popup_ref":"auspicious_time_popup_ref"},"events":[{"name_en":"Parinirvana of Tulku Pegyal Rinpoche (1931–2001)","name_bo":"སྤྲུལ་སྐུ་བད་རྒྱལ་རིན་པོ་ཆེ།་འདས་མཆོད།","category_en":"Parinirvana","category_bo":"མྱང་འདས།","details_en":null,"details_bo":null,"image_key":"parinirvana_tulku_pegyal"}]}
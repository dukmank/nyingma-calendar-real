{"date_key":"2026-06-18","tibetan_year_name_en":"Fire Horse","image_key":"dzongsar_khyentse","gregorian":{"year":2026,"year_bo":"༢༠༢༦","month_en":"JUN","month_bo":"ཕྱི་ཟླ་དྲུག་པ།","date":18,"date_bo":"༡༨","weekday_en":"Thursday","weekday_bo":"ཕུར་བུ།"},"tibetan":{"year_en":"2153","year_bo":"༢༡༥༣","year_name_en":"Fire Horse","year_name_bo":"མེ་ཕོ་རྟ་ལོ།","month_en":"5","month_bo":"༥༽","month_name_en":"Nron-Dawa","month_name_bo":"སྣྲོན་ཟླ་བ།","animal_month_en":"Monkey","animal_month_bo":"སྤྲེལ་ཟླ།","day_en":"4","day_bo":"༤༽","lunar_status_en":null,"lunar_status_bo":null},"significance":{"day_significance_en":"The practice of all the bodhisattvas is to take refuge in the Three Jewels, Since they will never fail to provide protection for all who call upon them, For whom are the ordinary gods of this world ever capable of helping, As long as they themselves are trapped within saṃsāra’s vicious cycle?","day_significance_bo":"རང་ཡང་འཁོར་བའི་བཙོན་རར་བཅིངས་པ་ཡིས། །འཇིག་རྟེན་ལྷ་ཡིས་སུ་ཞིག་སྐྱོབ་པར་ནུས། །དེ་ཕྱིར་གང་ལ་སྐྱབས་ན་མི་བསླུ་བའི། །དཀོན་མཆོག་སྐྱབས་འགྲོ་རྒྱལ་སྲས་ལག་ལེན་ཡིན།","element_combo_en":"Wind-Wind","element_combo_bo":"རླུང་རླུང་།","meaning_of_coincidence_en":"Certainty: Fulfills wishes speedily; resolves disputes.","meaning_of_coincidence_bo":"ཕུན་ཚོགས།"},"auspicious_day":null,"astrology_cards":[{"type":"naga_day","status_en":"avoid","status_bo":"ངན།","image_key":"astrology_naga_days_sleep","popup_ref":"naga-sleep_popup_ref"},{"type":"flag_day","status_en":"auspicious","status_bo":"བཟང་།","image_key":"astrology_flag_days","popup_ref":"flag_popup_ref"},{"type":"fire_ritual","status_en":"avoid","status_bo":"ངན།","image_key":"astrology_fire_rituals","popup_ref":"fire_popup_ref"},{"type":"hair_cutting","status_en":"auspicious","status_bo":"བཟང་།","image_key":"astrology_hair_cutting","popup_ref":"hair_cutting_popup_ref"}],"torma_offering":{"direction_en":"northeast","image_key":"astrology_torma_offerings","popup_ref":"torma_popup_ref"},"empty_vase":{"direction_en":"south","image_key":"astrology_empty_vase","popup_ref":"empty_vase_popup_ref"},"daily_restriction":{"description_en":"avoid Legal or Military Action","image_key":"astrology_daily_restrictions_military","popup_ref":"daily_restrictions_popup_ref"},"auspicious_times":{"description_en":"5:00 AM · 12:00 PM · 5:00 PM · 12:00 AM","image_key":"astrology_auspicious_time","popup_ref":"auspicious_time_popup_ref"},"events":[{"name_en":"Birthday of H.H. Dzongsar Khyentse Rinpoche","name_bo":"༸སྐྱབས་རྗེ་རྫོང་སར་མཁྱེན་བརྩེ་རིན་པོ་ཆེའི་འཁྲུངས་སྐར།   བདུད་འཇོམས་གཏེར་གསར།","category_en":"Birthday","category_bo":"འཁྲུངས་སྐར།","details_en":"The one and only father of all Buddhas is Mañjuśrī,\nManifesting as the incomparable human master, Jamyang Khyentse Wangpo,\nHis blessing emanation is Dilgo Khyentse Rinpoche, Tashi Paljor:\nTo you I pray! Bless my mind and inspire my understanding!\nTexts by and about Kyabje Dilgo Khyentse Rinpoche, Tashi Paljor (dil mgo mkhyen brtse bkra shis dpal 'byor, 1910-1991):","details_bo":"༈ རྒྱལ་ཀུན་ཡབ་གཅིག་རྗེ་བཙུན་འཇམ་དཔལ་དབྱངས། །\nམཚུངས་མེད་དགེ་བའི་བཤེས་ཚུལ་མཁྱེན་བརྩེའི་དབང༌། །\nདེ་ཡི་བྱིན་རླབས་བཀྲ་ཤིས་དཔལ་གྱི་འབྱོར། །\nགསོལ་བ་འདེབས་སོ་བདག་རྒྱུད་བྱིན་གྱིས་རློབས། །\nསྐྱབས་རྗེ་དིལ་མགོ་མཁྱེན་བརྩེ་རིན་པོ་ཆེ་བཀྲ་ཤིས་དཔལ་འབྱོར་ (༡༩༡༠–༡༩༩༡) ཞབས་ཀྱི་གསུང་རྩོམ་དང་ཁོང་གི་སྐོར་གྱི་བརྩམས་ཆོས་ཁག","image_key":"dzongsar_khyentse"},{"name_en":"Parinirvana of Jamyang Khyentse Chökyi Lodro (1893–1959)","name_bo":"འཇམ་དབྱངས་མཁྱེན་བརྩེ་ཆོས་ཀྱི་བློ་གྲོས།་འདས་མཆོད།","category_en":"Parinirvana","category_bo":"མྱང་འདས།","details_en":null,"details_bo":null,"image_key":"parinirvana_jamyang_khyentse"}]}
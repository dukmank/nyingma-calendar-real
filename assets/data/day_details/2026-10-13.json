ection_en":"south","image_key":"astrology_empty_vase","popup_ref":"empty_vase_popup_ref"},"daily_restriction":{"description_en":"avoid Birth Celebrations","image_key":"astrology_daily_restrictions_baby","popup_ref":"daily_restrictions_popup_ref"},"auspicious_times":{"description_en":"11:00 AM · 9:00 PM · 4:00 AM","image_key":"astrology_auspicious_time","popup_ref":"auspicious_time_popup_ref"},"events":[{"name_en":"Parinirvana of H.H. Kathok Gertse Rinpoche","name_bo":"༸སྐྱབས་རྗེ་ཀ་ཐོག་དགེ་བརྩེ་རིན་པོ་ཆེའི་འདས་མཆོད།","category_en":"Parinirvana","category_bo":"མྱང་འདས།","details_en":"Supplication to the 4th Katok Getse Rinpoche\nMaster of the entire Doctrine of the Buddha, the Katokpa,\nUpholder of the Victory Banner of the Teachings with Unchanging Activity,\nCrown Ornament of millions of scholars and realized masters, the Getsepa,\nTo the Fearless Lord of Speech, I pray!\nThis beautiful supplication (gsol 'debs) for the 4th H.H. Katok Getse Rinpoche, Gyurme Tenpa Gyaltsen, was composed by the H.H. Kyabje Dilgo Khyentse Rinpoche","details_bo":"ཀཿ་ཐོག་དགེ་རྩེ་རིན་པོ་ཆེའི་གསོལ་འདེབས།\nཐུབ་བསྟན་ཡོངས་རྫོགས་མངའ་བདག་ཀཿ་ཐོག་པ། །\nའགྱུར་མེད་ཕྲིན་ལས་བསྟན་པའི་རྒྱལ་མཚན་འཛིན། །\nམཁས་གྲུབ་བྱེ་བའི་གཙུག་རྒྱན་དགེ་རྩེ་བ། །\nའཇིགས་མེད་ངག་གི་དབང་པོར་གསོལ་བ་འདེབས། །\n\n\nཀཿ་ཐོག་དགེ་རྩེ་རིན་པོ་ཆེ་སྐུ་ཕྲེང་བཞི་པ་འགྱུར་མེད་བསྟན་པ་རྒྱལ་མཚན་མཆོག་གི་གསོལ་འདེབས་ངོ་མཚར་ཅན་འདི་ནི། ༧སྐྱབས་རྗེ་དིལ་མགོ་མཁྱེན་བརྩེ་རིན་པོ་ཆེ་མཆོག་གིས་ལྗགས་རྩོམ་གནང་བ་ཞིག་ལགས་སོ།།","image_key":"kathok_gertse_rinpoche"},{"name_en":"Book Launch Ceremony: Release of a publication on the \"Three Skills\" (teaching, debating, and writing) held on the memorial of the Omniscient Rigzin Jigme Lingpa (1729–1798).","name_bo":"ཀུན་མཁྱེན་རིག་འཛིན་འཇིགས་མེད་གླིང་པའི་འདས་མཆོད་ལ་འཆད་རྩོད་རྩོམ་གསུམ་དང་འབྲེལ་བའི་རྩོམ་དེབ་དབུ་འབྱེད་མཛད་སྒོ།   1729-1798","category_en":"Annual Festival","category_bo":"འཁྲུངས་སྐར།","details_en":null,"details_bo":null,"image_key":"event_jigmelingpa_booklaunch"},{"name_en":"Parinirvana of Rigdzin Jikme Lingp
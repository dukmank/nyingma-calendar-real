{"date_key":"2026-07-06","tibetan_year_name_en":"Fire Horse","image_key":"his_holiness_the_14th_dalai_lama","gregorian":{"year":2026,"year_bo":"༢༠༢༦","month_en":"JUL","month_bo":"ཕྱི་ཟླ་བདུན་པ།","date":6,"date_bo":"༦","weekday_en":"Monday","weekday_bo":"ཟླ་བ།"},"tibetan":{"year_en":"2153","year_bo":"༢༡༥༣","year_name_en":"Fire Horse","year_name_bo":"མེ་ཕོ་རྟ་ལོ།","month_en":"5","month_bo":"༥༽","month_name_en":"Nron-Dawa","month_name_bo":"སྣྲོན་ཟླ་བ།","animal_month_en":"Monkey","animal_month_bo":"སྤྲེལ་ཟླ།","day_en":"21","day_bo":"༢༡","lunar_status_en":null,"lunar_status_bo":null},"significance":{"day_significance_en":"The practice of all the bodhisattvas is never to entertain concepts, Which revolve around dualistic notions of perceiver and perceived, In the knowledge that all these appearances are but the mind itself, Whilst mind’s own nature is forever beyond the limitations of ideas.","day_significance_bo":"ཇི་ལྟར་སྣང་བ་འདི་དག་རང་གི་སེམས། །སེམས་ཉིད་གདོད་ནས་སྤྲོས་པའི་མཐའ་དང་བྲལ། །དེ་ཉིད་ཤེས་ནས་གཟུང་འཛིན་མཚན་མ་རྣམས། །ཡིད་ལ་མི་བྱེད་རྒྱལ་སྲས་ལག་ལེན་ཡིན།","element_combo_en":"Water-Earth","element_combo_bo":"ཆུ་ས།","meaning_of_coincidence_en":"Youthfulness: Brings lasting peace; good for celebrations.","meaning_of_coincidence_bo":"བསིལ་བ།"},"auspicious_day":null,"astrology_cards":[{"type":"naga_day","status_en":"avoid","status_bo":"ངན།","image_key":"astrology_naga_days_sleep","popup_ref":"naga-sleep_popup_ref"},{"type":"flag_day","status_en":"auspicious","status_bo":"བཟང་།","image_key":"astrology_flag_days","popup_ref":"flag_popup_ref"},{"type":"fire_ritual","status_en":"avoid","status_bo":"ངན།","image_key":"astrology_fire_rituals","popup_ref":"fire_popup_ref"},{"type":"hair_cutting","status_en":"neutral","status_bo":"རྒྱུན་ལྡན།","image_key":"astrology_hair_cutting","popup_ref":"hair_cutting_popup_ref"}],"torma_offering":{"direction_en":"northeast","image_key":"astrology_torma_offerings","popup_ref":"torma_popup_ref"},"empty_vase":{"direction_en":"west","image_key":"astrology_empty_vase","popup_ref":"empty_vase_popup_ref"},"daily_restriction":{"description_en":"avoid Hosting Guests","image_key":"astrology_daily_restrictions_guest","popup_ref":"daily_restrictions_popup_ref"},"auspicious_times":{"description_en":"7:00 AM · 2:00 PM · 11:00 PM","image_key":"astrology_auspicious_time","popup_ref":"auspicious_time_popup_ref"},"events":[{"name_en":"Birthday of His Holiness the 14th Dalai Lama","name_bo":"༸གོང་ས་མཆོག་གི་འཁྲུངས་སྐར།","category_en":"Birthday","category_bo":"འཁྲུངས་སྐར།","details_en":"Gang-ri ra-wä kor-wä zhing-kham dir\nIn the land encircled by a wall of snow mountains,\nPhän-dang de-wa ma-lü jung-wä nä\nThe source of all happiness and benefit without exception,\nChän-rä-zig-wang Tän-dzin Gya-tsho la\nIs the Lord of Compassion, Tenzin Gyatso.\nZhab-pä si-thä bar-du tän-gyur chig\nMay your lotus feet remain steadfast until the end of existence.","details_bo":"གངས་རིའི་རྭ་བས་བསྐོར་བའི་ཞིང་ཁམས་འདིར།\nཕན་དང་བདེ་བ་མ་ལུས་འབྱུང་བའི་གནས།\nསྤྱན་རས་གཟིགས་དབང་བསྟན་འཛིན་རྒྱ་མཚོ་ཡི།\nཞབས་པད་སྲིད་མཐའི་བར་དུ་བརྟན་གྱུར་ཅིག","image_key":"his_holiness_the_14th_dalai_lama"}]}
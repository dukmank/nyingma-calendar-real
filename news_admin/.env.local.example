# Supabase — copy from: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Backblaze B2 — copy from: B2 Cloud Storage → Buckets → App Keys
B2_KEY_ID=YOUR_B2_KEY_ID
B2_APP_KEY=YOUR_B2_APP_KEY
B2_BUCKET_ID=YOUR_B2_BUCKET_ID
B2_BUCKET_NAME=nyingma-assets2
B2_PUBLIC_URL=https://f005.backblazeb2.com/file/nyingma-assets2
